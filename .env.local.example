# Supabase PostgreSQL session pooler connection string.
# Copy this file to .env.local and replace the placeholders with the session pooler values from Supabase.
# Keep the real value only in .env.local or your deployment environment.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Optional NPC / Agent provider.
# Default is rules, which does not send user-entered content to external model services.
QUEST_AGENT_PROVIDER=rules

# Only set these when you explicitly allow backend model calls.
# Agnes is treated as an OpenAI-compatible Chat Completions provider.
# QUEST_AGENT_PROVIDER=agnes
# AGNES_API_KEY=replace-with-local-secret
# AGNES_BASE_URL=https://replace-with-agnes-openai-compatible-base-url/v1
# AGNES_MODEL=replace-with-agnes-model-name

# OpenAI Responses API remains available for development fallback.
# QUEST_AGENT_PROVIDER=openai
# OPENAI_API_KEY=replace-with-local-secret
# OPENAI_MODEL=gpt-4.1-mini
